# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Storage Settings
CHROMA_DATA_PATH=./chroma_data

# Pipeline Hyperparameters
MAX_FILE_SIZE_BYTES=10485760 # 10MB in bytes
CHUNK_SIZE=500               # Target tokens per chunk
CHUNK_OVERLAP=50             # Token overlap between chunks
TOP_K=4                      # Number of chunks retrieved for Q&A
SIM_THRESHOLD=0.5            # Minimum similarity threshold to skip LLM calls (0 to 1)

# Application Versions
PROMPT_VERSION=v1.0          # Tracks system prompt versioning in logs and outputs
LLM_PROVIDER=openai          # Pluggable LLM provider (openai)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2 # Local sentence-transformer model used

